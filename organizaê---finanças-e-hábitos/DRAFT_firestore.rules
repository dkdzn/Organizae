rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'initialBalance', 'createdAt']) &&
             data.keys().size() <= 6 && // email, initialBalance, displayName, createdAt, updatedAt
             data.email is string && data.email.size() <= 256 &&
             data.initialBalance is number &&
             data.createdAt is timestamp;
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'category', 'description', 'date', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['INCOME', 'EXPENSE'] &&
             data.amount is number &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 500 &&
             data.date is string && data.date.size() == 10 && // YYYY-MM-DD
             data.createdAt is timestamp;
    }

    // --- Goal Validation ---
    function isValidGoal(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'frequency', 'completedDates', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['FINANCIAL', 'HABIT'] &&
             data.title is string && data.title.size() <= 200 &&
             data.frequency in ['DAILY', 'WEEKLY', 'MONTHLY'] &&
             data.completedDates is list && data.completedDates.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // --- Reminder Validation ---
    function isValidReminder(data) {
      return data.keys().hasAll(['userId', 'title', 'time', 'daysOfWeek', 'active', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.time is string && data.time.size() == 5 && // HH:mm
             data.daysOfWeek is list && data.daysOfWeek.size() <= 7 &&
             data.active is bool &&
             data.createdAt is timestamp;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'initialBalance', 'updatedAt']);

      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(transactionId);
        allow create: if isOwner(userId) && isValidTransaction(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['type', 'amount', 'category', 'description', 'date', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(transactionId);
      }

      match /goals/{goalId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(goalId);
        allow create: if isOwner(userId) && isValidGoal(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(goalId) && isValidGoal(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'targetAmount', 'currentAmount', 'frequency', 'completedDates', 'deadline', 'category', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(goalId);
      }

      match /reminders/{reminderId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(reminderId);
        allow create: if isOwner(userId) && isValidReminder(incoming()) && incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidId(reminderId) && isValidReminder(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'time', 'daysOfWeek', 'active', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(reminderId);
      }
    }
  }
}
