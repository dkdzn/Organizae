{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "initialBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "email", "initialBalance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "description", "date"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A financial or habit goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["FINANCIAL", "HABIT"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "frequency": { "type": "string", "enum": ["DAILY", "WEEKLY", "MONTHLY"] },
        "completedDates": { "type": "array", "items": { "type": "string" } },
        "deadline": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "title", "frequency", "completedDates"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A recurring reminder",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "daysOfWeek": { "type": "array", "items": { "type": "integer" } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "time", "daysOfWeek", "active"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User's goals"
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "User's reminders"
    }
  }
}
